{
	"version": 3,
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"settings": {
		"appearanceTools": true,
		"color": {
			"background": true,
			"customDuotone": false,
			"customGradient": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"slug": "primary",
					"color": "#512d6d",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#6c757d",
					"name": "Secondary"
				},
				{
					"slug": "dark",
					"color": "#221c45",
					"name": "Dark"
				},
				{
					"slug": "white",
					"color": "#fff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000",
					"name": "Black"
				},
				{
					"slug": "success",
					"color": "#198754",
					"name": "Success"
				},
				{
					"slug": "info",
					"color": "#0dcaf0",
					"name": "Info"
				},
				{
					"slug": "warning",
					"color": "#ffc107",
					"name": "Warning"
				},
				{
					"slug": "danger",
					"color": "#dc3545",
					"name": "Danger"
				}
			],
			"text": true,
			"heading": true,
			"button": true
		},
		"dimensions": {
			"aspectRatio": true,
			"minHeight": true
		},
		"layout": {
			"contentSize": "768px",
			"wideSize": "1320px"
		},
		"spacing": {
			"blockGap": true,
			"customSpacingSize": false,
			"margin": true,
			"padding": true,
			"spacingSizes": [
				{
					"name": "None",
					"size": "0",
					"slug": "none"
				},
				{
					"name": "Extra Small",
					"size": ".25rem",
					"slug": "xs"
				},
				{
					"name": "Small",
					"size": ".5rem",
					"slug": "sm"
				},
				{
					"name": "Base",
					"size": "1rem",
					"slug": "base"
				},
				{
					"name": "Large",
					"size": "1.5rem",
					"slug": "lg"
				},
				{
					"name": "Extra Large",
					"size": "3rem",
					"slug": "xl"
				}
			]
		},
		"typography": {
			"customFontSize": false,
			"defaultFontSizes": false,
			"lineHeight": false,
			"dropCap": false,
			"fluid": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"textDecoration": true,
			"textTransform": true,
			"fontSizes": [
				{
					"slug": "root",
					"size": "1rem",
					"name": "Root",
					"fluid": false
				},
				{
					"slug": "base",
					"size": "1.35rem",
					"name": "Body",
					"fluid": false
				},
				{
					"slug": "sm",
					"size": "1.2rem",
					"name": "Small (H6)",
					"fluid": true
				},
				{
					"slug": "md",
					"size": "1.44rem",
					"name": "Medium (H5)",
					"fluid": true
				},
				{
					"slug": "lg",
					"size": "1.728rem",
					"name": "Large (H4)",
					"fluid": true
				},
				{
					"slug": "xl",
					"size": "2.074rem",
					"name": "XL (H3)",
					"fluid": true
				},
				{
					"slug": "2xl",
					"size": "2.488rem",
					"name": "2XL (H2)",
					"fluid": true
				},
				{
					"slug": "3xl",
					"size": "2.986rem",
					"name": "3XL (H1)",
					"fluid": true
				}
			],
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Gill Sans Nova",
					"fontFamily": "gill-sans-nova, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\""
				}
			]
		},
		"custom": {
			"lineHeight": "calc(4px + 2.5ex)",
			"transitionTiming": ".15s",
			"transitionEasing": "ease-in-out",
			"transition": "var:custom|transition-timing var:custom|transition-easing"
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/details": {
				"color": {
					"background": "var:preset|color|white",
					"text": "var:preset|color|dark"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|base",
						"right": "var:preset|spacing|lg",
						"bottom": "var:preset|spacing|base",
						"left": "var:preset|spacing|lg"
					},
					"blockGap": "var:preset|spacing|base"
				}
			},
			"core/button": {
				"border": {
					"radius": "0",
					"width": "2px",
					"color": "var:preset|color|primary"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|sm",
						"right": "var:preset|spacing|lg",
						"bottom": "var:preset|spacing|sm",
						"left": "var:preset|spacing|lg"
					},
					"blockGap": "var:preset|spacing|base"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontSize": "var:preset|font-size|base"
				},
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|white"
				}
			},
			"core/image": {
				"variations": {
					"rounded": {
						"border": {
							"radius": "0"
						}
					}
				}
			},
			"core/paragraph": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontFamily": "var:preset|font-family|body"
				}
			},
			"core/list": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontFamily": "var:preset|font-family|body"
				}
			},
			"core/list-item": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontFamily": "var:preset|font-family|body"
				}
			},
			"core/heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|body"
				}
			}
		},
		"typography": {
			"fontSize": "var:preset|font-size|base",
			"lineHeight": "1.5",
			"fontWeight": "400",
			"fontFamily": "var:preset|font-family|body"
		},
		"elements": {
			"link": {
				"css": "transition: color var(--transition-standard);text-underline-offset:.25em",
				"color": {
					"text": "var:preset|color|primary"
				},
				":hover": {
					"color": {
						"text": "#512d6dcc"
					}
				},
				":visited": {
					"color": {
						"text": "var:preset|color|primary"
					}
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "700"
				},
				"spacing": {
					"margin": {
						"bottom": "0.5rem",
						"top": "0"
					}
				},
				"css": "text-wrap:balance;"
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|3-xl"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|2-xl"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|xl"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|lg"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|md"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|sm"
				}
			}
		}
	}
}
